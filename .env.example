# ─── Banco de Dados ────────────────────────────────────────────────────────────
# Instale MySQL: brew install mysql && brew services start mysql
# Crie o banco: mysql -u root -e "CREATE DATABASE adflow;"
DATABASE_URL=mysql://root:@localhost:3306/adflow

# ─── Segurança ─────────────────────────────────────────────────────────────────
# Gere uma string aleatória forte (ex: openssl rand -base64 32)
JWT_SECRET=troque-por-uma-string-aleatoria-forte

# ─── App ───────────────────────────────────────────────────────────────────────
VITE_APP_ID=adflow

# ─── IA (configure ao menos uma opção para habilitar funcionalidades de IA) ────
# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ─── Google Calendar / OAuth (opcional) ────────────────────────────────────────
# 1) Crie credenciais OAuth no Google Cloud Console
# 2) Adicione redirect URIs:
#    - http://localhost:3000/api/oauth/google/callback         (Google Agenda)
#    - http://localhost:3000/api/oauth/google/login/callback   (Login Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Opcional: sobrescreve redirects inferidos automaticamente
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback
# GOOGLE_LOGIN_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/login/callback

# ─── Armazenamento de arquivos (opcional) ──────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=adflow-assets
